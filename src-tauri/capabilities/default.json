{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "stronghold:default",
    "updater:default",
    "dialog:default",
    "process:default",
    {
      "identifier": "fs:allow-exists",
      "allow": [{ "path": "$APPLOCALDATA/redmine-dashboard.hold" }]
    },
    {
      "identifier": "fs:allow-remove",
      "allow": [{ "path": "$APPLOCALDATA/redmine-dashboard.hold" }]
    }
  ]
}
