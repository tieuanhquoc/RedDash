{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "RedDash",
  "version": "../package.json",
  "identifier": "redmine.dashboard",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:9990",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "",
        "width": 1280,
        "height": 820,
        "minWidth": 960,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false,
        "transparent": true,
        "titleBarStyle": "Overlay"
      }
    ],
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost; img-src 'self' asset: http://asset.localhost data:; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self' ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "macOS": {
      "entitlements": "tauri.app.entitlements"
    },
    "windows": {
      "webviewInstallMode": { "type": "embedBootstrapper" }
    },
    "publisher": "Tieu Anh Quoc",
    "homepage": "https://tieuanhquoc.info/",
    "copyright": "© 2026 Tieu Anh Quoc",
    "category": "Productivity",
    "shortDescription": "Redmine time tracking dashboard",
    "longDescription": "RedDash — log and visualize your Redmine time entries with an interactive calendar and team view. Credentials are stored locally in an encrypted Stronghold vault.",
    "license": "MIT",
    "licenseFile": "../LICENSE",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/tieuanhquoc/RedDash/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDlGQjNENDU1NURBMkJBNzUKUldSMXVxSmRWZFN6bjM5c2E4dlJVYUdNTmc3NHhJOU5abVpZdlI2NGtmVWQ5M2hJa3hFbHU3ODcK",
      "dialog": false
    }
  }
}